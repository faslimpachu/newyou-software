generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  mr               String    @id
  consultationType String
  patientName      String
  parentName       String
  gender           String
  mobileNumber     String
  address          String
  district         String
  state            String
  pinCode          String
  dob              DateTime?
  age              Int?
  bloodGroup       String?
  status           String?

  emergencyContactName       String?
  emergencyContactPhone      String?
  emergencyContactRelation   String?
  allergies                  String?
  conditions                 String?
  medications                String?
  smoking                    String?
  alcohol                    String?
  exercise                   String?
  diet                       String?

  createdAt        DateTime  @default(now())

  visits           Visit[]
  opSheets         OPSheet[]
  prescriptions    Prescription[]
  nutritionAssessments NutritionAssessment[]
  ayurcareTreatments  AyurcareTreatment[]
  followUps        FollowUp[]
  documents        Document[]

  @@unique([mobileNumber])
  @@map("patients")
}

model Visit {
  id                  String   @id @default(uuid())
  patientMr           String
  doctor              String?
  dietitian           String?
  appointmentDate     DateTime?
  appointmentTimeSlot String?
  status              String   @default("Waiting")
  createdAt           DateTime @default(now())

  patient             Patient       @relation(fields: [patientMr], references: [mr], onDelete: Cascade)
  opSheet             OPSheet?

  @@map("visits")
}

model OPSheet {
  id                  String   @id @default(uuid())
  patientMr           String
  visitId             String   @unique
  clinicalExamination String?
  vitals              String?
  diagnosis           String?
  symptoms            String?
  status              String?
  createdAt           DateTime @default(now())

  patient             Patient     @relation(fields: [patientMr], references: [mr], onDelete: Cascade)
  visit               Visit       @relation(fields: [visitId], references: [id], onDelete: Cascade)
  prescription        Prescription?

  @@map("op_sheets")
}

model Prescription {
  id             String   @id @default(uuid())
  patientMr      String
  opSheetId      String   @unique
  diagnosis      String?
  medicines      String?
  advice         String?
  followUp       String?
  doctorSignature String?
  createdAt      DateTime @default(now())

  patient        Patient   @relation(fields: [patientMr], references: [mr], onDelete: Cascade)
  opSheet        OPSheet   @relation(fields: [opSheetId], references: [id], onDelete: Cascade)

  @@map("prescriptions")
}

model NutritionAssessment {
  id              String    @id @default(uuid())
  patientMr       String
  assessmentDate  DateTime
  program         String?
  weight          Float?
  bmi             Float?
  bodyFat         Float?
  dietPlan        String?
  observations    String?
  recommendations String?
  notes           String?
  reviewDate      DateTime?
  dietitian       String?
  createdAt       DateTime  @default(now())

  patient Patient @relation(fields: [patientMr], references: [mr], onDelete: Cascade)

  @@map("nutrition_assessments")
}

model AyurcareTreatment {
  id             String    @id @default(uuid())
  patientMr      String
  diagnosis      String?
  treatmentPlan  String?
  medicines      String?
  procedures     String?
  therapies      String?
  advice         String?
  practitioner   String?
  reviewDate     DateTime?
  notes          String?
  createdAt      DateTime @default(now())

  patient Patient @relation(fields: [patientMr], references: [mr], onDelete: Cascade)

  @@map("ayurcare_treatments")
}

model FollowUp {
  id          String    @id @default(uuid())
  patientMr   String
  program     String?
  reviewDate  DateTime?
  dueDate     DateTime?
  assignedTo  String?
  priority    String?
  status      String?
  remarks     String?
  createdAt   DateTime @default(now())

  patient     Patient @relation(fields: [patientMr], references: [mr], onDelete: Cascade)

  @@map("follow_ups")
}

model Invoice {
  id              Int      @id @default(autoincrement())
  invoiceNumber   String   @unique
  center          String
  billType        String
  patientName     String
  patientMrNumber String
  patientAge      String?
  patientDob      String?
  patientGender   String?
  patientBloodGroup String?
  patientAddress  String?
  patientContact  String?
  invoiceDate     String
  discount        Float     @default(0)
  tax             Float     @default(0)
  paid            Float     @default(0)
  paymentMethod   String?
  subtotal        Float?
  grandTotal      Float?
  balance         Float?
  status          String?
  createdAt       DateTime @default(now())

  items           InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(uuid())
  invoiceId Int
  name      String
  quantity  Float
  rate      Float

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Document {
  id          String   @id @default(uuid())
  patientMr   String
  title       String?
  category    String?
  fileName    String
  filePath    String
  fileType    String?
  uploadedBy  String?
  remarks     String?
  uploadedAt  DateTime @default(now())

  patient     Patient @relation(fields: [patientMr], references: [mr], onDelete: Cascade)

  @@map("documents")
}

model Staff {
  id         String   @id @default(uuid())
  name       String
  role       String
  email      String?
  phone      String?
  centerType String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("staff")
}

model MRSequence {
  id         String   @id @default(uuid())
  centerType String   @unique
  lastNumber Int      @default(0)
  updatedAt  DateTime @default(now())

  @@map("mr_sequences")
}
